{
  "name": "matico-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend para guardar PDFs de cuadernos escaneados",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test:supabase": "node db/test_connection.js",
    "migrate": "node scripts/migrate_sheets_to_supabase.js",
    "migrate:dry": "node scripts/migrate_sheets_to_supabase.js --dry-run",
    "pregenerate:math-bank": "node scripts/pregenerateQuestionBank.js --subject MATEMATICA",
    "pregenerate:language-bank": "node scripts/pregenerateQuestionBank.js --subject LENGUAJE",
    "pregenerate:physics-bank": "node scripts/pregenerateQuestionBank.js --subject FISICA",
    "gen:math": "node scripts/pregenerateWithImages.js --subject MATEMATICA",
    "gen:lenguaje": "node scripts/pregenerateWithImages.js --subject COMPETENCIA_LECTORA",
    "gen:fisica": "node scripts/pregenerateWithImages.js --subject FISICA",
    "gen:retrofit:math": "node scripts/pregenerateWithImages.js --subject MATEMATICA --retrofit",
    "gen:retrofit:lenguaje": "node scripts/pregenerateWithImages.js --subject COMPETENCIA_LECTORA --retrofit",
    "gen:retrofit:fisica": "node scripts/pregenerateWithImages.js --subject FISICA --retrofit",
    "gen:quimica": "node scripts/pregenerateWithImages.js --subject QUIMICA",
    "gen:biologia": "node scripts/pregenerateWithImages.js --subject BIOLOGIA",
    "gen:historia": "node scripts/pregenerateWithImages.js --subject HISTORIA",
    "gen:retrofit:quimica": "node scripts/pregenerateWithImages.js --subject QUIMICA --retrofit",
    "gen:retrofit:biologia": "node scripts/pregenerateWithImages.js --subject BIOLOGIA --retrofit",
    "gen:retrofit:historia": "node scripts/pregenerateWithImages.js --subject HISTORIA --retrofit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "googleapis": "^128.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "openai": "^4.20.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
